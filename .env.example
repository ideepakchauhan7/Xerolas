# Optional self-hosted gateway development variables.
# Do not put real production keys in this file.

CONTEXT_AI_BACKEND_URL=http://127.0.0.1:8787
GEMINI_API_KEY=replace-with-your-gemini-key
OPENROUTER_API_KEY=replace-with-your-openrouter-key
CONTEXT_AI_SESSION_SECRET=replace-with-a-long-random-session-secret

# Desktop BYOK keys are not read from .env; add them in Xerolas Settings.
# Development-only fallback if Electron safeStorage is unavailable:
# XEROLAS_ALLOW_PLAINTEXT_KEYS=1
