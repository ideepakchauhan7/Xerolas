{
  "name": "xerolas",
  "version": "0.1.31",
  "description": "AI screen intelligence for your desktop.",
  "main": "dist-electron/electron/main.js",
  "author": {
    "name": "Deepak Chauhan",
    "email": "ideepakchauhan7@users.noreply.github.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json --watch\" \"wait-on tcp:127.0.0.1:5173 file:dist-electron/electron/main.js && cross-env ELECTRON_DISABLE_SANDBOX=1 ELECTRON_RUN_AS_NODE= VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "node build/clean-output.js && npm run build:renderer && npm run build:main && node build/obfuscate-output.js",
    "build:renderer": "vite build",
    "build:main": "node build/build-electron.js",
    "start": "cross-env ELECTRON_DISABLE_SANDBOX=1 ELECTRON_RUN_AS_NODE= electron .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^41.5.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.27.7",
    "javascript-obfuscator": "^5.4.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "ai.xerolas.desktop",
    "productName": "Xerolas",
    "asar": true,
    "beforeBuild": "./build/before-build.js",
    "afterPack": "./build/after-pack.js",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/app-config.json",
        "to": "app-config.json"
      },
      {
        "from": "build/icons",
        "to": "icons"
      }
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icons/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "snap"
      ],
      "category": "Utility",
      "maintainer": "Deepak Chauhan <ideepakchauhan7@users.noreply.github.com>",
      "icon": "build/icons/linux",
      "synopsis": "AI screen intelligence for your desktop.",
      "description": "Capture any screen region and get an AI-powered answer in context.",
      "vendor": "Xerolas",
      "desktop": {
        "entry": {
          "Name": "Xerolas",
          "GenericName": "AI Screen Intelligence",
          "Comment": "Capture any screen region and get an AI-powered answer in context.",
          "Keywords": "AI;Screen;Capture;OCR;Translate;Summarize;Productivity;",
          "StartupNotify": "true"
        }
      }
    },
    "icon": "build/icons/icon.png",
    "nsis": {
      "artifactName": "Xerolas-Setup-${version}.${ext}"
    },
    "deb": {
      "packageName": "xerolas",
      "packageCategory": "utils",
      "priority": "optional",
      "vendor": "Xerolas",
      "maintainer": "Deepak Chauhan <ideepakchauhan7@users.noreply.github.com>",
      "synopsis": "AI screen intelligence for your desktop.",
      "description": "Capture any screen region and get an AI-powered answer in context.",
      "fpm": [
        "--license=MIT",
        "--vendor=Xerolas",
        "--url=https://xerolas.vercel.app"
      ],
      "desktop": {
        "entry": {
          "Name": "Xerolas",
          "GenericName": "AI Screen Intelligence",
          "Comment": "Capture any screen region and get an AI-powered answer in context.",
          "Keywords": "AI;Screen;Capture;OCR;Translate;Summarize;Productivity;",
          "StartupNotify": "true"
        }
      }
    },
    "snap": {
      "artifactName": "Xerolas-${version}-${arch}.${ext}",
      "title": "Xerolas",
      "summary": "AI screen intelligence for your desktop.",
      "description": "Capture any screen region and get an AI-powered answer in context. Use Xerolas to summarize, translate, extract text, explain code, and ask follow-up questions about the current capture without leaving your workflow.",
      "category": "Utility",
      "grade": "stable",
      "confinement": "strict",
      "base": "core22",
      "publish": null,
      "plugs": [
        "default"
      ],
      "environment": {
        "GTK_MODULES": "",
        "ELECTRON_RUN_AS_NODE": ""
      }
    }
  },
  "homepage": "https://xerolas.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ideepakchauhan7/Xerolas.git"
  },
  "bugs": {
    "url": "https://github.com/ideepakchauhan7/Xerolas/issues"
  }
}
