{
  "name": "xerolas",
  "version": "0.1.17",
  "description": "AI screen intelligence for your desktop.",
  "main": "dist-electron/electron/main.js",
  "author": {
    "name": "Deepak Chauhan",
    "email": "ideepakchauhan7@users.noreply.github.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json --watch\" \"tsc -p tsconfig.backend.json --watch\" \"wait-on file:dist-backend/backend/server.js && node --watch dist-backend/backend/server.js\" \"wait-on tcp:127.0.0.1:5173 tcp:127.0.0.1:8787 file:dist-electron/electron/main.js && cross-env ELECTRON_DISABLE_SANDBOX=1 ELECTRON_RUN_AS_NODE= VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:worker": "wrangler dev --port 8787",
    "build": "node build/clean-output.js && npm run build:renderer && npm run build:main && npm run build:backend && node build/obfuscate-output.js",
    "build:renderer": "vite build",
    "build:main": "node build/build-electron.js",
    "build:backend": "tsc -p tsconfig.backend.json",
    "start": "cross-env ELECTRON_DISABLE_SANDBOX=1 ELECTRON_RUN_AS_NODE= electron .",
    "start:backend": "node dist-backend/backend/server.js",
    "deploy:worker": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.backend.json --noEmit",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.27.7",
    "javascript-obfuscator": "^5.4.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wait-on": "^8.0.1",
    "wrangler": "^4.83.0"
  },
  "build": {
    "appId": "ai.xerolas.desktop",
    "productName": "Xerolas",
    "asar": true,
    "beforeBuild": "./build/before-build.js",
    "afterPack": "./build/after-pack.js",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/app-config.json",
        "to": "app-config.json"
      },
      {
        "from": "build/icons",
        "to": "icons"
      }
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icons/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Deepak Chauhan <ideepakchauhan7@users.noreply.github.com>",
      "icon": "build/icons/linux",
      "synopsis": "AI screen intelligence for your desktop."
    },
    "icon": "build/icons/icon.png",
    "nsis": {
      "artifactName": "Xerolas-Setup-${version}.${ext}"
    }
  }
}
